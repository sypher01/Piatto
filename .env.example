# ─────────────────────────────────────────────────────
# Piatto — variabili d'ambiente
# Copia questo file in .env e compila i valori.
# ─────────────────────────────────────────────────────

# Password PostgreSQL (obbligatoria)
POSTGRES_PASSWORD=cambia_questa_password

# Valori opzionali (defaults mostrati)
POSTGRES_DB=hfresh_recipes
POSTGRES_USER=hfresh_user

# Porte esposte sull'host
POSTGRES_PORT=5432
WEB_PORT=3006

# API LLM compatibile OpenAI per la normalizzazione ingredienti
# Supporta: LM Studio, Ollama, OpenAI, o qualsiasi endpoint compatibile.
LLM_BASE_URL=http://localhost:1234/v1
# Lascia vuoto per auto-rilevare il modello, oppure specifica:
LLM_MODEL=
